                <REQUIREMENT UUID="x04000000001B6AE6">
                  <SHORT-NAME>BehaviorDescription_Turbo_boost_pressure_presentation_information</SHORT-NAME>
                  <CATEGORY></CATEGORY>
                  <NAME>BehaviorDescription_Turbo_boost_pressure_presentation_information</NAME>
                  <OWNED-COMMENTS/>
                  <TEXT>Description:
Powertrain shall send the current Turbo boost pressure value to the HMI. HMI shall then display the current value in precent of the max turbo pressure. The max turbo boost pressure value in a parameter is powertrain responsible to set to the correct value. Powertrain shall not request this parameter. </TEXT>
                  <FORMALISM></FORMALISM>
                  <URL></URL>
                  <MODE-REFS/>
                </REQUIREMENT>
                <REQUIREMENT UUID="x04000000001BDA3A">
                  <SHORT-NAME>BehaviorDescription_Idle_Adjust_Information</SHORT-NAME>
                  <CATEGORY></CATEGORY>
                  <NAME>BehaviorDescription_Idle_Adjust_Information</NAME>
                  <OWNED-COMMENTS/>
                  <TEXT>Inform driver when idle speed is successfully stored</TEXT>
                  <FORMALISM></FORMALISM>
                  <URL></URL>
                  <MODE-REFS/>
                </REQUIREMENT>
