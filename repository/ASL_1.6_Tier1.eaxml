                  <CATEGORY></CATEGORY>
                  <NAME>Debouncing_of_input_devices</NAME>
                  <OWNED-COMMENTS/>
                  <TEXT>Reading of input devices shall include suitable debouncing to ensure that a reliable value is read.
</TEXT>
                  <FORMALISM></FORMALISM>
                  <URL></URL>
                  <MODE-REFS/>
                </REQUIREMENT>
                <REQUIREMENT UUID="x04000000001A9F8C">
