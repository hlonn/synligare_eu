                    <SATISFIED-REQUIREMENT-REF TYPE="REQUIREMENT">/Extensions/RequirementsPackage/SafetyRequirements/Safety_TorqueRequestLower</SATISFIED-REQUIREMENT-REF>
                    <SATISFIED-REQUIREMENT-REF TYPE="REQUIREMENT">/Extensions/RequirementsPackage/SafetyRequirements/Safety_TorqueRequestUpper</SATISFIED-REQUIREMENT-REF>
                  </SATISFIED-REQUIREMENT-REFS>
