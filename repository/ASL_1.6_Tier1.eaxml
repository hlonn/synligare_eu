                  <MODE-REFS/>
                </REQUIREMENT>
                <REQUIREMENT UUID="x04000000001B8D96">
                  <SHORT-NAME>EscAutoNeutralManagement</SHORT-NAME>
                  <CATEGORY></CATEGORY>
                  <NAME>EscAutoNeutralManagement</NAME>
                  <OWNED-COMMENTS/>
                  <TEXT>The management of engine speed control  via the autoneutral shall follow the sub requirements.
</TEXT>
                  <FORMALISM></FORMALISM>
                  <URL></URL>
