                  <SHORT-NAME>BehaviorDescription_Instrument_test_of_segment_displays</SHORT-NAME>
                  <CATEGORY></CATEGORY>
                  <NAME>BehaviorDescription_Instrument_test_of_segment_displays</NAME>
                  <OWNED-COMMENTS/>
                  <TEXT></TEXT>
                  <FORMALISM></FORMALISM>
