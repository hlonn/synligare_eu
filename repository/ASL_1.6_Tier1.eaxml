                    </SATISFIED-BY-IREF>
                  </SATISFIED-BY-IREFS>
                </SATISFY>
                <SATISFY UUID="x04000000007FA020">
                  <SHORT-NAME>TSR</SHORT-NAME>
                  <CATEGORY></CATEGORY>
                  <NAME>TSR</NAME>
                  <OWNED-COMMENTS/>
                  <SATISFIED-REQUIREMENT-REFS>
                    <SATISFIED-REQUIREMENT-REF TYPE="REQUIREMENT">/Extensions/RequirementsPackage/AnalysisLevelRequirements/TSR_A1</SATISFIED-REQUIREMENT-REF>
                    <SATISFIED-REQUIREMENT-REF TYPE="REQUIREMENT">/Extensions/RequirementsPackage/AnalysisLevelRequirements/TSR_A2</SATISFIED-REQUIREMENT-REF>
                    <SATISFIED-REQUIREMENT-REF TYPE="REQUIREMENT">/Extensions/RequirementsPackage/AnalysisLevelRequirements/TSR_A3</SATISFIED-REQUIREMENT-REF>
                    <SATISFIED-REQUIREMENT-REF TYPE="REQUIREMENT">/Extensions/RequirementsPackage/AnalysisLevelRequirements/TSR_A4</SATISFIED-REQUIREMENT-REF>
                  </SATISFIED-REQUIREMENT-REFS>
                  <SATISFIED-USE-CASE-REFS/>
                  <SATISFIED-BY-IREFS>
                    <SATISFIED-BY-IREF>
                      <IDENTIFIABLE-TARGET-REF TYPE="ANALYSIS-FUNCTION-TYPE">/Structure/AnalysisLevelelements/FcnTypes/ASL_FunctionalAnalysisArchitecture</IDENTIFIABLE-TARGET-REF>
                    </SATISFIED-BY-IREF>
                    <SATISFIED-BY-IREF>
                      <IDENTIFIABLE-TARGET-REF TYPE="DESIGN-FUNCTION-TYPE">/Structure/DesignLevelelements/FunctionalDesignElements/TSR/TSR</IDENTIFIABLE-TARGET-REF>
                    </SATISFIED-BY-IREF>
                  </SATISFIED-BY-IREFS>
                </SATISFY>
              </OWNED-RELATIONSHIPS>
              <OPERATIONAL-SITUATIONS/>
              <REQUIREMENTS>
                <REQUIREMENT UUID="x04000000007F9FFB">
                  <SHORT-NAME>FSC_tooHigh</SHORT-NAME>
                  <CATEGORY></CATEGORY>
                  <NAME>FSC_tooHigh</NAME>
                  <OWNED-COMMENTS/>
                  <TEXT></TEXT>
                  <FORMALISM></FORMALISM>
                  <URL></URL>
                  <MODE-REFS/>
                </REQUIREMENT>
                <REQUIREMENT>
                  <SHORT-NAME>TSR_A1</SHORT-NAME>
                  <CATEGORY>Proposed</CATEGORY>
                  <NAME></NAME>
                  <OWNED-COMMENTS/>
                  <TEXT>The traffic sign speed shall be updated when a new traffic speed sign is detected and classified.</TEXT>
                  <FORMALISM></FORMALISM>
                  <URL></URL>
                  <MODE-REFS/>
                </REQUIREMENT>
                <REQUIREMENT>
                  <SHORT-NAME>TSR_A2</SHORT-NAME>
                  <CATEGORY>Proposed</CATEGORY>
                  <NAME></NAME>
                  <OWNED-COMMENTS/>
                  <TEXT>A detected traffic sign shall be classified to preliminary or final</TEXT>
                  <FORMALISM></FORMALISM>
                  <URL></URL>
                  <MODE-REFS/>
                </REQUIREMENT>
                <REQUIREMENT>
                  <SHORT-NAME>TSR_A3</SHORT-NAME>
                  <CATEGORY>Proposed</CATEGORY>
                  <NAME></NAME>
                  <OWNED-COMMENTS/>
                  <TEXT>For each classified traffic sign there shall be a confidence value</TEXT>
                  <FORMALISM></FORMALISM>
                  <URL></URL>
                  <MODE-REFS/>
                </REQUIREMENT>
