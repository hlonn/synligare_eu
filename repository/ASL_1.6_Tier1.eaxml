                    </SATISFIED-BY-IREF>
                  </SATISFIED-BY-IREFS>
                </SATISFY>
              </OWNED-RELATIONSHIPS>
              <OPERATIONAL-SITUATIONS/>
              <REQUIREMENTS>
                <REQUIREMENT UUID="x04000000005FBD27">
                  <SHORT-NAME>RespectSpeedLimit</SHORT-NAME>
                  <CATEGORY></CATEGORY>
                  <NAME>RespectSpeedLimit</NAME>
                  <OWNED-COMMENTS/>
                  <TEXT>The speed limit should be respected.</TEXT>
                  <FORMALISM></FORMALISM>
                  <URL></URL>
                  <MODE-REFS/>
                </REQUIREMENT>
                <REQUIREMENT UUID="x04000000007F9E86">
                  <SHORT-NAME>KeepSpeedBelowSpeedLimitation</SHORT-NAME>
                  <CATEGORY></CATEGORY>
                  <NAME>KeepSpeedBelowSpeedLimitation</NAME>
                  <OWNED-COMMENTS/>
                  <TEXT></TEXT>
                  <FORMALISM></FORMALISM>
                  <URL></URL>
                  <MODE-REFS/>
                </REQUIREMENT>
                <REQUIREMENT UUID="x04000000007F9EEA">
                  <SHORT-NAME>AvoidUnintendedSpeedDrop</SHORT-NAME>
                  <CATEGORY></CATEGORY>
                  <NAME>AvoidUnintendedSpeedDrop</NAME>
                  <OWNED-COMMENTS/>
                  <TEXT></TEXT>
                  <FORMALISM></FORMALISM>
                  <URL></URL>
                  <MODE-REFS/>
                </REQUIREMENT>
                <REQUIREMENT>
                  <SHORT-NAME>Safety_TorqueRequestUpper</SHORT-NAME>
                  <CATEGORY></CATEGORY>
                  <NAME></NAME>
                  <OWNED-COMMENTS/>
                  <TEXT>Torque request shall not be higher than 110% of requested value</TEXT>
                  <FORMALISM></FORMALISM>
                  <URL></URL>
                  <MODE-REFS/>
                </REQUIREMENT>
                <REQUIREMENT>
                  <SHORT-NAME>Safety_TorqueRequestLower</SHORT-NAME>
                  <CATEGORY></CATEGORY>
                  <NAME></NAME>
                  <OWNED-COMMENTS/>
                  <TEXT>Torque request shall not be lower than 80% of requested value</TEXT>
                  <FORMALISM></FORMALISM>
                  <URL></URL>
                  <MODE-REFS/>
                </REQUIREMENT>
              </REQUIREMENTS>
              <REQUIREMENTS-RELATIONSHIP-GROUPS/>
              <REQUIREMENTS-HIERARCHYS/>
              <USE-CASES/>
              <REQUIREMENT-TYPES/>
            </REQUIREMENTS-MODEL>
            <REQUIREMENTS-MODEL UUID="x04000000007FA016">
              <SHORT-NAME>AnalysisLevelRequirements</SHORT-NAME>
              <CATEGORY></CATEGORY>
              <NAME>AnalysisLevelRequirements</NAME>
              <OWNED-COMMENTS/>
              <TRACEABLE-SPECIFICATION-REFS/>
              <OWNED-RELATIONSHIPS>
                <SATISFY UUID="x04000000007FA020">
                  <SHORT-NAME>ASLSatisfy</SHORT-NAME>
