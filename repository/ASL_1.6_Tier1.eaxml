                  <CATEGORY></CATEGORY>
                  <NAME>BehaviorDescription_VehicleOverspeed_VM</NAME>
                  <OWNED-COMMENTS/>
                  <TEXT>Pre-overspeed alert:
Warning for the driver before overspeed alarm on (15 second before the overspeed alarm). Only available for P2683.

Overspeed alarm:
This alert inform the driver that he overtakes the allowed speed for one minute.
</TEXT>
                  <FORMALISM></FORMALISM>
                  <URL></URL>
                  <MODE-REFS/>
                </REQUIREMENT>
                <REQUIREMENT UUID="x04000000001B2D4F">
